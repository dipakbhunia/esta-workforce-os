generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  TRIAL
  SUSPENDED
}

enum RoleName {
  SUPER_ADMIN
  COMPANY_ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  TEMPORARY
}

enum WorkMode {
  ONSITE
  REMOTE
  HYBRID
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum AttendanceStatus {
  PRESENT
  LATE
  HALF_DAY
  ABSENT
  AUTO_PUNCHED_OUT
}

enum AttendanceLogType {
  PUNCH_IN
  PUNCH_OUT
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum MonitoringDeviceStatus {
  ACTIVE
  INACTIVE
  REVOKED
}

model Company {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  slug               String
  status             CompanyStatus      @default(TRIAL)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?
  branches           Branch[]
  departments        Department[]
  designations       Designation[]
  shifts             Shift[]
  users              User[]
  employees          Employee[]
  attendances        Attendance[]
  leaveTypes         LeaveType[]
  leaveRequests      LeaveRequest[]
  leaveBalances      LeaveBalance[]
  breakPolicies      BreakPolicy[]
  attendancePolicies AttendancePolicy[]
  monitoringDevices  MonitoringDevice[]
  heartbeats         Heartbeat[]
  activitySessions   ActivitySession[]
  screenshots        Screenshot[]
  applicationUsages  ApplicationUsage[]
  websiteUsages      WebsiteUsage[]
  roles              Role[]
  auditLogs          AuditLog[]

  @@index([status])
  @@index([slug])
  @@index([deletedAt])
}

model Branch {
  id          String       @id @default(uuid()) @db.Uuid
  companyId   String       @db.Uuid
  name        String
  code        String
  address     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departments Department[]
  users       User[]
  employees   Employee[]

  @@index([companyId])
  @@index([companyId, code])
  @@index([deletedAt])
}

model Department {
  id           String        @id @default(uuid()) @db.Uuid
  companyId    String        @db.Uuid
  branchId     String?       @db.Uuid
  name         String
  code         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch       Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  designations Designation[]
  users        User[]
  employees    Employee[]

  @@index([companyId])
  @@index([companyId, code])
  @@index([branchId])
  @@index([deletedAt])
}

model Designation {
  id           String      @id @default(uuid()) @db.Uuid
  companyId    String      @db.Uuid
  departmentId String?     @db.Uuid
  name         String
  code         String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  users        User[]
  employees    Employee[]

  @@index([companyId])
  @@index([companyId, code])
  @@index([departmentId])
  @@index([deletedAt])
}

model Shift {
  id        String     @id @default(uuid()) @db.Uuid
  companyId String     @db.Uuid
  name      String
  code      String
  startTime String
  endTime   String
  timezone  String     @default("UTC")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users     User[]
  employees Employee[]

  @@index([companyId])
  @@index([companyId, code])
  @@index([deletedAt])
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  companyId     String?        @db.Uuid
  branchId      String?        @db.Uuid
  departmentId  String?        @db.Uuid
  designationId String?        @db.Uuid
  shiftId       String?        @db.Uuid
  email         String         @unique
  passwordHash  String
  firstName     String
  lastName      String
  status        UserStatus     @default(ACTIVE)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  company       Company?       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch        Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  department    Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation   Designation?   @relation(fields: [designationId], references: [id], onDelete: SetNull)
  shift         Shift?         @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  roles         UserRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]     @relation("AuditLogActor")
  employee      Employee?

  @@index([companyId])
  @@index([branchId])
  @@index([departmentId])
  @@index([status])
  @@index([deletedAt])
}

model Employee {
  id                           String             @id @default(uuid()) @db.Uuid
  userId                       String             @unique @db.Uuid
  companyId                    String             @db.Uuid
  branchId                     String?            @db.Uuid
  departmentId                 String?            @db.Uuid
  designationId                String?            @db.Uuid
  shiftId                      String?            @db.Uuid
  reportingManagerId           String?            @db.Uuid
  employeeCode                 String
  joiningDate                  DateTime           @db.Date
  employmentType               EmploymentType
  workMode                     WorkMode
  status                       EmployeeStatus     @default(ACTIVE)
  phone                        String?
  alternatePhone               String?
  personalEmail                String?
  emergencyContactName         String?
  emergencyContactRelationship String?
  emergencyContactPhone        String?
  addressLine1                 String?
  addressLine2                 String?
  city                         String?
  state                        String?
  postalCode                   String?
  country                      String?
  documents                    Json?
  createdAt                    DateTime           @default(now())
  updatedAt                    DateTime           @updatedAt
  deletedAt                    DateTime?
  user                         User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  company                      Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch                       Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  department                   Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation                  Designation?       @relation(fields: [designationId], references: [id], onDelete: SetNull)
  shift                        Shift?             @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  reportingManager             Employee?          @relation("EmployeeReporting", fields: [reportingManagerId], references: [id], onDelete: SetNull)
  directReports                Employee[]         @relation("EmployeeReporting")
  attendances                  Attendance[]
  leaveRequests                LeaveRequest[]     @relation("LeaveRequestEmployee")
  approvedLeaveRequests        LeaveRequest[]     @relation("LeaveRequestApprover")
  leaveBalances                LeaveBalance[]
  monitoringDevices            MonitoringDevice[]
  heartbeats                   Heartbeat[]
  activitySessions             ActivitySession[]
  screenshots                  Screenshot[]
  applicationUsages            ApplicationUsage[]
  websiteUsages                WebsiteUsage[]

  @@index([companyId])
  @@index([companyId, employeeCode])
  @@index([branchId])
  @@index([departmentId])
  @@index([designationId])
  @@index([shiftId])
  @@index([reportingManagerId])
  @@index([status])
  @@index([deletedAt])
}

model Attendance {
  id                 String           @id @default(uuid()) @db.Uuid
  companyId          String           @db.Uuid
  employeeId         String           @db.Uuid
  attendanceDate     DateTime         @db.Date
  punchInAt          DateTime?
  punchOutAt         DateTime?
  status             AttendanceStatus @default(PRESENT)
  workedMinutes      Int              @default(0)
  breakMinutes       Int              @default(0)
  lateMinutes        Int              @default(0)
  expectedMinutes    Int
  shiftStartTime     String
  shiftEndTime       String
  shiftTimezone      String
  notes              String?
  autoPunchOutReason String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  company            Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee           Employee         @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  logs               AttendanceLog[]
  breaks             BreakLog[]

  @@unique([employeeId, attendanceDate])
  @@index([companyId, attendanceDate])
  @@index([employeeId, attendanceDate])
  @@index([status])
}

model AttendanceLog {
  id           String            @id @default(uuid()) @db.Uuid
  attendanceId String            @db.Uuid
  type         AttendanceLogType
  occurredAt   DateTime          @default(now())
  note         String?
  attendance   Attendance        @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([attendanceId, occurredAt])
}

model BreakLog {
  id              String       @id @default(uuid()) @db.Uuid
  attendanceId    String       @db.Uuid
  breakPolicyId   String?      @db.Uuid
  breakTypeName   String?
  breakTypeCode   String?
  allowedMinutes  Int?
  isPaid          Boolean?
  startedAt       DateTime     @default(now())
  endedAt         DateTime?
  durationMinutes Int?
  policyViolated  Boolean      @default(false)
  autoPunchOutAt  DateTime?
  note            String?
  attendance      Attendance   @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  breakPolicy     BreakPolicy? @relation(fields: [breakPolicyId], references: [id], onDelete: SetNull)

  @@index([attendanceId, startedAt])
  @@index([breakPolicyId])
  @@index([policyViolated])
}

model BreakPolicy {
  id                    String     @id @default(uuid()) @db.Uuid
  companyId             String     @db.Uuid
  name                  String
  code                  String
  allowedMinutes        Int
  isPaid                Boolean    @default(false)
  isActive              Boolean    @default(true)
  autoPunchOutOnTimeout Boolean    @default(true)
  sortOrder             Int        @default(0)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  deletedAt             DateTime?
  company               Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  breaks                BreakLog[]

  @@index([companyId])
  @@index([companyId, code])
  @@index([companyId, isActive])
  @@index([deletedAt])
}

model LeaveType {
  id                String         @id @default(uuid()) @db.Uuid
  companyId         String         @db.Uuid
  name              String
  code              String
  description       String?
  defaultDays       Float          @default(0)
  requiresApproval  Boolean        @default(true)
  managerCanApprove Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?
  company           Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  requests          LeaveRequest[]
  balances          LeaveBalance[]

  @@index([companyId])
  @@index([companyId, code])
  @@index([deletedAt])
}

model LeaveRequest {
  id            String             @id @default(uuid()) @db.Uuid
  companyId     String             @db.Uuid
  employeeId    String             @db.Uuid
  leaveTypeId   String             @db.Uuid
  startDate     DateTime           @db.Date
  endDate       DateTime           @db.Date
  totalDays     Float
  reason        String?
  status        LeaveRequestStatus @default(PENDING)
  approverId    String?            @db.Uuid
  reviewedAt    DateTime?
  reviewComment String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?
  company       Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee      Employee           @relation("LeaveRequestEmployee", fields: [employeeId], references: [id], onDelete: Restrict)
  leaveType     LeaveType          @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  approver      Employee?          @relation("LeaveRequestApprover", fields: [approverId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([employeeId, startDate])
  @@index([leaveTypeId])
  @@index([deletedAt])
}

model LeaveBalance {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String    @db.Uuid
  employeeId  String    @db.Uuid
  leaveTypeId String    @db.Uuid
  year        Int
  allocated   Float     @default(0)
  used        Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveTypeId, year])
  @@index([companyId, year])
}

model AttendancePolicy {
  id                          String   @id @default(uuid()) @db.Uuid
  companyId                   String   @db.Uuid
  autoPunchOutOnHeartbeatLoss Boolean  @default(true)
  heartbeatTimeoutMinutes     Int      @default(30)
  isActive                    Boolean  @default(true)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  company                     Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId, isActive])
}

model MonitoringDevice {
  id                String                 @id @default(uuid()) @db.Uuid
  companyId         String                 @db.Uuid
  employeeId        String                 @db.Uuid
  deviceIdentifier  String
  deviceName        String
  platform          String
  osVersion         String?
  appVersion        String?
  status            MonitoringDeviceStatus @default(ACTIVE)
  lastSeenAt        DateTime?
  registeredAt      DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  deletedAt         DateTime?
  company           Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee          Employee               @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  heartbeats        Heartbeat[]
  activitySessions  ActivitySession[]
  screenshots       Screenshot[]
  applicationUsages ApplicationUsage[]
  websiteUsages     WebsiteUsage[]

  @@unique([employeeId, deviceIdentifier])
  @@index([companyId, status])
  @@index([employeeId, status])
  @@index([lastSeenAt])
  @@index([deletedAt])
}

model Heartbeat {
  id          String           @id @default(uuid()) @db.Uuid
  companyId   String           @db.Uuid
  employeeId  String           @db.Uuid
  deviceId    String           @db.Uuid
  recordedAt  DateTime         @default(now())
  idleSeconds Int              @default(0)
  isOnline    Boolean          @default(true)
  metadata    Json?
  createdAt   DateTime         @default(now())
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  device      MonitoringDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([companyId, recordedAt])
  @@index([employeeId, recordedAt])
  @@index([deviceId, recordedAt])
}

model ActivitySession {
  id                String             @id @default(uuid()) @db.Uuid
  companyId         String             @db.Uuid
  employeeId        String             @db.Uuid
  deviceId          String             @db.Uuid
  clientSessionId   String
  startedAt         DateTime
  endedAt           DateTime
  activeSeconds     Int                @default(0)
  idleSeconds       Int                @default(0)
  keystrokeCount    Int?
  mouseClickCount   Int?
  metadata          Json?
  createdAt         DateTime           @default(now())
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee          Employee           @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  device            MonitoringDevice   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  applicationUsages ApplicationUsage[]
  websiteUsages     WebsiteUsage[]

  @@unique([deviceId, clientSessionId])
  @@index([companyId, startedAt])
  @@index([employeeId, startedAt])
  @@index([deviceId, startedAt])
}

model Screenshot {
  id                 String           @id @default(uuid()) @db.Uuid
  companyId          String           @db.Uuid
  employeeId         String           @db.Uuid
  deviceId           String           @db.Uuid
  clientScreenshotId String
  capturedAt         DateTime
  storageKey         String
  mimeType           String
  sizeBytes          Int?
  width              Int?
  height             Int?
  checksum           String?
  metadata           Json?
  createdAt          DateTime         @default(now())
  deletedAt          DateTime?
  company            Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee           Employee         @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  device             MonitoringDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, clientScreenshotId])
  @@index([companyId, capturedAt])
  @@index([employeeId, capturedAt])
  @@index([deviceId, capturedAt])
  @@index([deletedAt])
}

model ApplicationUsage {
  id                String           @id @default(uuid()) @db.Uuid
  companyId         String           @db.Uuid
  employeeId        String           @db.Uuid
  deviceId          String           @db.Uuid
  activitySessionId String           @db.Uuid
  applicationName   String
  windowTitle       String?
  startedAt         DateTime
  endedAt           DateTime
  durationSeconds   Int
  createdAt         DateTime         @default(now())
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee          Employee         @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  device            MonitoringDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  activitySession   ActivitySession  @relation(fields: [activitySessionId], references: [id], onDelete: Cascade)

  @@index([companyId, startedAt])
  @@index([employeeId, startedAt])
  @@index([deviceId, startedAt])
  @@index([activitySessionId])
  @@index([applicationName])
}

model WebsiteUsage {
  id                String           @id @default(uuid()) @db.Uuid
  companyId         String           @db.Uuid
  employeeId        String           @db.Uuid
  deviceId          String           @db.Uuid
  activitySessionId String           @db.Uuid
  browserName       String?
  domain            String
  url               String?
  pageTitle         String?
  startedAt         DateTime
  endedAt           DateTime
  durationSeconds   Int
  createdAt         DateTime         @default(now())
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee          Employee         @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  device            MonitoringDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  activitySession   ActivitySession  @relation(fields: [activitySessionId], references: [id], onDelete: Cascade)

  @@index([companyId, startedAt])
  @@index([employeeId, startedAt])
  @@index([deviceId, startedAt])
  @@index([activitySessionId])
  @@index([domain])
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  companyId   String?          @db.Uuid
  key         String
  name        String
  systemName  RoleName?
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  company     Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users       UserRole[]
  permissions RolePermission[]

  @@index([companyId])
  @@index([companyId, key])
  @@index([systemName])
  @@index([deletedAt])
}

model UserRole {
  userId     String   @db.Uuid
  roleId     String   @db.Uuid
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  assignedAt   DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model RefreshToken {
  id        String    @id @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String?  @db.Uuid
  actorUserId String?  @db.Uuid
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  actor       User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
}
