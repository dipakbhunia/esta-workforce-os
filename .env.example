# PostgreSQL
POSTGRES_DB=esta_workforce
POSTGRES_USER=esta
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432
DATABASE_URL=postgresql://esta:change_me@localhost:5432/esta_workforce?schema=public

# Backend
PORT=3000
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_different_long_random_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Development seed accounts
SEED_SUPER_ADMIN_EMAIL=superadmin@esta.local
SEED_SUPER_ADMIN_PASSWORD=SuperAdmin@123
SEED_COMPANY_ADMIN_EMAIL=admin@demo.esta.local
SEED_COMPANY_ADMIN_PASSWORD=CompanyAdmin@123

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ROOT_USER=esta_minio
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=localhost
MINIO_USE_SSL=false
