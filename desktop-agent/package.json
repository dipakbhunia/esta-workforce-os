{
  "name": "esta-workforce-os-desktop-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform desktop agent foundation for Esta Workforce OS",
  "main": "./out/main/index.cjs",
  "author": "Esta Workforce OS",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "build": "npm run typecheck && electron-vite build",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.17.0"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "42.4.0",
    "electron-builder": "26.15.2",
    "electron-vite": "5.0.0",
    "typescript": "6.0.3",
    "vite": "7.3.5"
  },
  "build": {
    "appId": "com.esta.workforce.desktop",
    "productName": "Esta Workforce OS",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
